# ── Supabase (injecté automatiquement en prod ; nécessaire en local) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Front ──
APP_ORIGIN=https://contestation.ch

# ── Claude API (extraction bail — zero-retention) ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Gotenberg (HTML→PDF / screenshot, self-host CH) ──
GOTENBERG_URL=https://contestation-gotenberg.fly.dev
GOTENBERG_BASIC_AUTH=

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Clients Stripe autorisés à utiliser les deux promotions ADMIN de test.
STRIPE_ADMIN_PROMO_EMAIL=
# Offre à 14,90 CHF : remise fixe de 14,40 CHF, total 0,50 CHF.
STRIPE_ADMIN_PRINT_CUSTOMER_ID=
# Offre à 49,90 CHF : remise de 99 %, total arrondi Stripe 0,50 CHF.
STRIPE_ADMIN_RECOMMENDED_CUSTOMER_ID=
# Ancien nom, conservé comme fallback pour l'offre recommandée.
STRIPE_ADMIN_CUSTOMER_ID=

# ── Pingen (recommandé) ──
PINGEN_API_URL=https://api.pingen.com
PINGEN_TOKEN_URL=https://identity.pingen.com/auth/access-tokens
PINGEN_CLIENT_ID=
PINGEN_CLIENT_SECRET=
PINGEN_ORG_ID=

# ── Notifs exploitant + purge ──
OPERATOR_SLACK_WEBHOOK=
PURGE_SECRET=
