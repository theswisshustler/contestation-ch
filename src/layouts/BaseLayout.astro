---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  image?: string | null;
  type?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: unknown[];
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  image = '/assets/hero-lettre-contestation.png',
  type = 'website',
  noindex = false,
  jsonLd = [],
} = Astro.props;
const canonical = new URL(canonicalPath, Astro.site || Astro.url.origin).toString();
const ogImage = image ? new URL(image, Astro.site || Astro.url.origin).toString() : null;
const safeJson = (value: unknown) => JSON.stringify(value).replace(/</g, '\\u003c');
---
<!doctype html>
<html lang="fr-CH">
  <head>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-NFG6VWVP');</script>
    <!-- End Google Tag Manager -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <meta property="og:site_name" content="Contestation.ch" />
    <meta property="og:locale" content="fr_CH" />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="alternate" type="application/rss+xml" title="Guides Contestation.ch" href="/rss.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,600;12..96,700;12..96,800&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    {jsonLd.map((entry) => <script type="application/ld+json" set:html={safeJson(entry)} />)}
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NFG6VWVP"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <header class="site-header">
      <div class="site-header__inner">
        <a class="brand" href="/" aria-label="Contestation.ch — accueil">
          <img class="brand__logo" src="/assets/logo-contestation-color.svg" alt="Contestation.ch" />
        </a>
        <nav class="site-nav" aria-label="Navigation principale">
          <a href="/#parcours">Solutions</a>
          <a href="/blog">Guides</a>
          <a class="button button--secondary" href="/diagnostic">Vérifier <span class="button__optional">mon loyer</span></a>
        </nav>
      </div>
    </header>
    <main><slot /></main>
    <footer class="site-footer">
      <div class="site-footer__inner">
        <div class="site-footer__about">
          <a class="brand brand--footer" href="/" aria-label="Contestation.ch — accueil">
            <img class="brand__logo" src="/assets/logo-contestation-color.svg" alt="Contestation.ch" />
          </a>
          <p>Service indépendant d’aide à la rédaction — ni autorité publique, ni cabinet d’avocats, ni conseil juridique individualisé.</p>
        </div>
        <nav class="site-footer__nav" aria-label="Liens légaux"><a href="/?legal=cgv">CGV</a><br /><a href="/?legal=privacy">Confidentialité et mentions légales</a><br /><a href="/rss.xml">Flux RSS</a></nav>
      </div>
    </footer>
  </body>
</html>
