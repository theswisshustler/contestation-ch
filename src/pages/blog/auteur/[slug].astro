---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/blog/ArticleCard.astro';
import { getPublicAuthor, listPublishedArticles } from '../../../lib/blog.ts';

const slug = String(Astro.params.slug || '');
const page = Math.max(1, Number(Astro.url.searchParams.get('page')) || 1);
const [author, result] = await Promise.all([
  getPublicAuthor(slug),
  listPublishedArticles({ page: page - 1, pageSize: 24, author: slug }),
]);
if (!author) Astro.response.status = 404;
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=180, stale-while-revalidate=3600');
---
<BaseLayout
  title={author ? `${author.name} — Guides Contestation.ch` : 'Auteur introuvable — Contestation.ch'}
  description={author?.bio || 'Auteur des guides pratiques Contestation.ch.'}
  canonicalPath={`/blog/auteur/${slug}`}
>
  <div class="page-shell">
    {author ? <>
      <header class="page-intro">
        <p class="eyebrow">Auteur</p>
        <h1>{author.name}</h1>
        {author.bio && <p>{author.bio}</p>}
        {author.url && author.url !== 'https://contestation.ch/' && <p><a href={author.url} rel="me noopener">Site de l’auteur</a></p>}
      </header>
      {result.articles.length
        ? <div class="article-grid">{result.articles.map((article) => <ArticleCard article={article} />)}</div>
        : <div class="empty-state"><h2>Aucun guide publié</h2><a href="/blog">Revenir aux guides</a></div>}
    </> : <div class="empty-state"><h1>Auteur introuvable</h1><a href="/blog">Revenir aux guides</a></div>}
  </div>
</BaseLayout>
